# Totem playground — copy to .env and fill in your keys
# The playground's totem.config.ts defaults to Anthropic for compile/review
# (claude-sonnet-4-6) and Ollama for embeddings. Provide ANTHROPIC_API_KEY
# and an Ollama host at minimum. GEMINI_API_KEY and OPENAI_API_KEY are kept
# as alternate provider fallbacks if you switch orchestrator/embedding in
# totem.config.ts.

ANTHROPIC_API_KEY=your_key_here

# Ollama — embeddings backend. Defaults to http://localhost:11434 if unset.
OLLAMA_HOST=http://localhost:11434

# Alternate provider credentials (optional)
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
